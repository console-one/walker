{
  "name": "@console-one/walker",
  "version": "0.1.1",
  "description": "Path-based tree walker framework with a JSONPath walker implementation. Register handlers against dotted paths, walk a value, and receive per-path callbacks.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/console-one/walker.git"
  },
  "bugs": {
    "url": "https://github.com/console-one/walker/issues"
  },
  "homepage": "https://github.com/console-one/walker#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "jsonpath",
    "walker",
    "tree",
    "visitor"
  ],
  "author": "Andrew Chalmers",
  "license": "MIT",
  "dependencies": {
    "@console-one/multimap": "^0.1.0",
    "@console-one/subscription": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
